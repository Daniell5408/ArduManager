<Window x:Class="ArdulibsManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ArdulibsManager.ViewModels"
        mc:Ignorable="d"
        Title="Arduino GitHub Library Manager" Height="520" Width="700"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RescanCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1,1,0,0" Padding="10">
            <DockPanel>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" />
                <ProgressBar DockPanel.Dock="Right" Width="160" Height="14" IsIndeterminate="{Binding IsBusy}" Margin="12,0,0,0" />
            </DockPanel>
        </Border>

        <TabControl Margin="10">
            <TabItem Header="Поиск">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBox FontSize="16" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Минимум 3 символа" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SearchResults}" Margin="0,0,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,4" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Url}" Foreground="#666" Margin="0,0,0,1" FontSize="11" />
                                                <TextBlock Text="{Binding InstalledLibrary.Version, StringFormat=Установлена версия {0}}" FontSize="11" />
                                                <TextBlock Text="{Binding Status}" Foreground="#A45" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ComboBox Width="84" MinWidth="84" Margin="8,0,0,0"
                                                          ItemsSource="{Binding Tags}"
                                                          SelectedItem="{Binding SelectedTag}"
                                                          DisplayMemberPath="DisplayName"
                                                          DropDownOpened="VersionComboBox_DropDownOpened"
                                                          MaxDropDownHeight="220"
                                                          IsTextSearchEnabled="False"
                                                          ToolTip="Пока версия не выбрана, установка берёт latest GitHub tag" />
                                                <Button Content="{Binding InstallButtonText}" Command="{Binding DataContext.InstallCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Установленные">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Обновить список" Width="150" Height="30" Command="{Binding RescanCommand}" />
                        <Button Content="Обновить библиотеки" Width="150" Height="30" Margin="8,0,0,0" Command="{Binding UpdateAllCommand}" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InstalledLibraries}" Margin="0,0,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,4" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="270" />
                                                <TextBlock Text="{Binding Version, StringFormat= v{0}}" FontSize="14" Margin="8,0,0,0" Foreground="#555" />
                                                <TextBlock Text="  • есть обновление" FontSize="12" Margin="8,2,0,0" Foreground="#A45">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <Button Content="Обновить" Width="79" Height="30" Margin="0,0,4,0" ToolTip="Установить свежую версию" Command="{Binding DataContext.UpdateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <Button Content="Открыть" Width="75" Height="30" Margin="0,0,4,0" ToolTip="Открыть папку библиотеки" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <Button Content="Удалить" Width="75" Height="30" Margin="0,0,0,0" ToolTip="Удалить библиотеку" Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Настройки">
                <StackPanel Margin="12" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="Папка Arduino libraries" FontWeight="SemiBold" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Выбрать" Width="86" Command="{Binding BrowseLibrariesCommand}" />
                        <Button DockPanel.Dock="Right" Content="Открыть" Width="86" Command="{Binding OpenFolderCommand}" Margin="4,0,4,0" />
                        <TextBox Text="{Binding LibrariesPath, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <TextBlock Text="Список репозиториев" FontWeight="SemiBold" Margin="4,16,4,0" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Обновить" Width="86" Command="{Binding RefreshRegistryCommand}" />
                        <TextBox Text="{Binding RepositoryListUrl, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <TextBlock Text="GitHub token (опционально, для повышения лимитов)" FontWeight="SemiBold" Margin="4,16,4,0" />
                    <TextBox Text="{Binding GitHubToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <CheckBox Content="Проверять обновления при запуске" IsChecked="{Binding CheckUpdatesOnStartup}" Margin="4,0,4,12" />

                    <Button Content="Сохранить настройки" Width="180" HorizontalAlignment="Left" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Лог">
                <ListBox ItemsSource="{Binding Logs}" Margin="8" FontFamily="Consolas" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

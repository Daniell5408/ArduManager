<Window x:Class="ArduManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ArduManager.ViewModels"
        xmlns:views="clr-namespace:ArduManager.Views"
        mc:Ignorable="d"
        Title="Arduino Packet Manager" Height="560" Width="820"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RescanCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="UnifiedCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CardVersionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="Margin" Value="6,1,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CardSecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CardComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="105" />
            <Setter Property="MinWidth" Value="105" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1,1,0,0" Padding="10">
            <DockPanel>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" />
                <ProgressBar DockPanel.Dock="Right" Width="160" Height="14" IsIndeterminate="{Binding IsBusy}" Margin="12,0,0,0" />
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Margin="10" SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="Поиск библиотек">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <Grid>
                            <TextBox x:Name="LibrarySearchTextBox"
                                     Height="30"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Минимум 3 символа" />
                            <TextBlock Text="Название библиотеки"
                                       Foreground="#9CA3AF"
                                       FontSize="14"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=LibrarySearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SearchResults}" Margin="0,0,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource UnifiedCardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitleTextStyle}" MaxWidth="430" />
                                                    <TextBlock Text="{Binding InstalledBadge}" Style="{StaticResource CardVersionTextStyle}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#A45"
                                                           FontSize="11"
                                                           Margin="0,1,0,0"
                                                           Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <ComboBox Style="{StaticResource CardComboBoxStyle}"
                                                          ItemsSource="{Binding Tags}"
                                                          SelectedItem="{Binding SelectedTag}"
                                                          DisplayMemberPath="DisplayName"
                                                          DropDownOpened="VersionComboBox_DropDownOpened"
                                                          MaxDropDownHeight="220"
                                                          IsTextSearchEnabled="False"
                                                          ToolTip="Пока версия не выбрана, установка берёт latest GitHub tag" />
                                                <Button Content="{Binding InstallButtonText}"
                                                        Style="{StaticResource CardButtonStyle}"
                                                        Command="{Binding DataContext.InstallCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Библиотеки">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Обновить список" Width="150" Height="30" Command="{Binding RescanCommand}" />
                        <Button Content="Обновить библиотеки" Width="150" Height="30" Margin="8,0,0,0" Command="{Binding UpdateAllCommand}" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InstalledLibraries}" Margin="0,0,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource UnifiedCardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitleTextStyle}" MaxWidth="310" />
                                                    <TextBlock Text="{Binding VersionBadge}" Style="{StaticResource CardVersionTextStyle}" />
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource CardSecondaryTextStyle}"
                                                           Visibility="{Binding HasGitHubUrl, Converter={StaticResource BoolToVisibility}}">
                                                    <Hyperlink NavigateUri="{Binding GitHubUrl}"
                                                               RequestNavigate="OpenHyperlink_RequestNavigate">
                                                        <Run Text="{Binding GitHubLinkText, Mode=OneWay}" />
                                                    </Hyperlink>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#A45"
                                                           FontSize="11"
                                                           Margin="0,1,0,0"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding HasVisibleStatus, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <Button Content="Обновить" ToolTip="Установить свежую версию" Style="{StaticResource CardButtonStyle}" Command="{Binding DataContext.UpdateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <Button Content="Открыть" ToolTip="Открыть папку библиотеки" Style="{StaticResource CardButtonStyle}" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <Button Content="Удалить" ToolTip="Удалить библиотеку" Style="{StaticResource CardButtonStyle}" Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem x:Name="PlatformsTab" Header="Платформы">
                <views:PlatformsView x:Name="PlatformsHost" />
            </TabItem>

            <TabItem Header="Настройки">
                <StackPanel Margin="12" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="Папка Arduino libraries" FontWeight="SemiBold" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Выбрать" Width="86" Height="30" Command="{Binding BrowseLibrariesCommand}" />
                        <Button DockPanel.Dock="Right" Content="Открыть" Width="86" Height="30" Command="{Binding OpenFolderCommand}" Margin="4,0,4,0" />
                        <TextBox Height="30" VerticalContentAlignment="Center" Text="{Binding LibrariesPath, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <TextBlock Text="Папка Arduino15" FontWeight="SemiBold" Margin="4,16,4,0" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Открыть" Width="86" Height="30" Command="{Binding OpenArduinoDataDirectoryCommand}" />
                        <TextBox Height="30" VerticalContentAlignment="Center" Text="{Binding ArduinoDataDirectory, Mode=OneWay}" IsReadOnly="True" Background="#F5F5F5" Foreground="#555" />
                    </DockPanel>

                    <TextBlock Text="Реестр библиотек" FontWeight="SemiBold" Margin="4,16,4,0" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Обновить" Width="86" Height="30" Command="{Binding RefreshRegistryCommand}" />
                        <TextBox Height="30" VerticalContentAlignment="Center" Text="{Binding RepositoryListUrl, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <TextBlock Text="GitHub token (опционально, для повышения лимитов)" FontWeight="SemiBold" Margin="4,16,4,0" />
                    <TextBox Height="30" VerticalContentAlignment="Center" Text="{Binding GitHubToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <CheckBox Content="Проверять обновления при запуске" IsChecked="{Binding CheckUpdatesOnStartup}" Margin="4,0,4,12" />

                    <Button Content="Сохранить настройки" Width="180" HorizontalAlignment="Left" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Лог">
                <ListBox ItemsSource="{Binding Logs}" Margin="8" FontFamily="Consolas" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

<UserControl x:Class="ArduManager.Views.PlatformsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <UserControl.Resources>
        <Style x:Key="PlatformCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="105" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="PackageUrlTextBox"
                         Text="{Binding NewPackageUrl, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Ссылка на package_*_index.json"
                         FontSize="14" />
                <TextBlock Text="Ссылка для менеджера плат"
                           Foreground="#9CA3AF"
                           FontSize="14"
                           Margin="9,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=PackageUrlTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <ComboBox Grid.Column="1"
                      Width="98"
                      ItemsSource="{Binding StandardPlatforms}"
                      SelectedItem="{Binding SelectedStandardPlatform, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      ToolTip="Стандартные ссылки на платформы" />
            <Button Grid.Column="2" Content="Добавить" Width="86" Command="{Binding AddUrlCommand}" />
            <Button Grid.Column="3" Content="Обновить" Width="86" Command="{Binding ReloadCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Platforms}" Margin="0,0,14,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PlatformCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Vertical"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding VersionBadge}"
                                                   FontSize="13"
                                                   FontWeight="Normal"
                                                   Foreground="#4B5563"
                                                   Margin="6,1,0,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock FontSize="11"
                                               Foreground="#666"
                                               Margin="0,1,0,0"
                                               Visibility="{Binding HasGitHubUrl, Converter={StaticResource BoolToVisibility}}"
                                               TextTrimming="CharacterEllipsis">
                                        <Hyperlink NavigateUri="{Binding GitHubUrl}"
                                                   RequestNavigate="OpenHyperlink_RequestNavigate">
                                            <Run Text="{Binding GitHubLinkText, Mode=OneWay}" />
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Versions}"
                                          SelectedItem="{Binding SelectedVersion, Mode=TwoWay}" />

                                <Button Grid.Column="2"
                                        Content="Установить"
                                        Command="{Binding InstallCommand}" />

                                <Button Grid.Column="3"
                                        Content="Удалить"
                                        Command="{Binding RemoveCommand}" />

                                <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                             Height="7" Minimum="0" Maximum="100"
                                             Value="{Binding ProgressValue}"
                                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                                             Margin="0,6,0,0" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                           Text="{Binding Status}"
                                           Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}"
                                           Foreground="#4B5563"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
